{
  "manifest_version": 3,
  "name": "Show Pilot",
  "version": "0.2.0",
  "description": "Show Pilot — AI presentation assistant powered by local Qwen3.5 (vision + text) via wllama",
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; worker-src 'self'; default-src 'self' data: blob:; connect-src 'self' data: blob: https://huggingface.co https://*.huggingface.co https://*.hf.co https://*.xethub.hf.co https://raw.githubusercontent.com"
  },
  "background": {
    "service_worker": "background.ts",
    "type": "module"
  },
  "action": {
    "default_title": "Show Pilot",
    "default_icon": {
      "16": "logo.png",
      "32": "logo.png",
      "48": "logo.png",
      "128": "logo.png"
    }
  },
  "icons": {
    "16": "logo.png",
    "32": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.zoho.com/*",
        "*://*.zoho.in/*",
        "*://*.zoho.eu/*",
        "*://*.zoho.com.au/*",
        "*://*.zoho.com.cn/*",
        "*://*.zohopublic.com/*",
        "*://*.localzoho.com/*"
      ],
      "js": ["content.ts"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "unlimitedStorage", "scripting", "activeTab", "tabs", "offscreen", "sidePanel", "debugger"],
  "host_permissions": ["<all_urls>"],
  "web_accessible_resources": [
    {
      "resources": ["offscreen.html"],
      "matches": []
    }
  ]
}
